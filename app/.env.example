# Copy to `.env.local` for local development. Values here are examples.
#
# For local Supabase (via `supabase start`), grab the URL and anon key printed
# by `supabase status`. For Vercel deploys, set these on the Vercel project
# (Production + Preview + Development) to the values from the Supabase
# dashboard -> Project Settings -> API.
#
# IMPORTANT: `PUBLIC_`-prefixed vars are exposed to the browser. Never put the
# `service_role` key here -- it bypasses RLS. The service role key is only
# used by integration tests and lives in `.env.test` (also gitignored).

PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key-from-supabase-status
